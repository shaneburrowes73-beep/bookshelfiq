# ============================================================
# BookShelfIQ — Environment Variables
# Copy this file to .env.local for local development
# Set these in Vercel Dashboard > Settings > Environment Variables
# ============================================================

# REQUIRED: Your Anthropic API key (enables live AI mode)
# Get one at: https://console.anthropic.com
# Without this, the app runs in demo mode with sample data
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OPTIONAL: Branding overrides (for white-labelling)
NEXT_PUBLIC_APP_NAME=BookShelfIQ
NEXT_PUBLIC_TAGLINE=Stop guessing your book's keywords. Start publishing strategically.
NEXT_PUBLIC_LOGO_TEXT=BookShelfIQ
NEXT_PUBLIC_COMPANY=BookShelfIQ
NEXT_PUBLIC_SUPPORT_EMAIL=support@bookshelfiq.com
